{
  "name": "desktop-browser",
  "version": "1.0.0",
  "description": "Desktop browser with anti-crawler bypass",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && cp -r src/renderer dist/renderer && electron .",
    "build": "tsc && cp -r src/renderer dist/renderer && electron-builder",
    "pack": "tsc && cp -r src/renderer dist/renderer && electron-builder --dir",
    "dist": "tsc && cp -r src/renderer dist/renderer && electron-builder"
  },
  "dependencies": {
    "playwright-core": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "typescript": "^5.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.rpa.desktop-browser",
    "productName": "AI浏览器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/renderer",
        "to": "renderer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}