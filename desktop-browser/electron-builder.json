{
  "appId": "com.rpa.desktop-browser",
  "productName": "AI浏览器",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": "dmg",
    "icon": "dist/main/icon.icns"
  },
  "win": {
    "target": "nsis",
    "icon": "dist/main/icon.ico"
  },
  "linux": {
    "target": "AppImage",
    "icon": "dist/main/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}