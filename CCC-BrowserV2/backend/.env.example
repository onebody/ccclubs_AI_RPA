# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rpa_user
DB_PASSWORD=rpa_password
DB_DATABASE=rpa_system

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# 服务配置
PORT=3000
HOST=127.0.0.1

# 加密密钥(32字节)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# Playwright配置
PLAYWRIGHT_TIMEOUT=30000
MAX_CONCURRENT_TASKS=10

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=logs/rpa-backend.log