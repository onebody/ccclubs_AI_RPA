# ============================
# Python 后端环境变量配置
# ============================

# 应用配置
APP_NAME=rpa-browser-v3
APP_ENV=development
DEBUG=true

# FastAPI 服务配置
SERVER_HOST=127.0.0.1
SERVER_PORT=8900

# PostgreSQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rpa_browser_v3
DB_USER=postgres
DB_PASSWORD=postgres

# Playwright 配置
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
CHROMIUM_PATH=

# 数据存储路径
DATA_DIR=../data
STORAGE_STATE_DIR=../data/storage_states
EXPORT_DIR=../data/exports

# 安全配置
API_KEY=
ENCRYPTION_KEY=

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=../data/logs
