{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "CCC-Browser V3",
  "version": "1.0.0",
  "identifier": "com.ccc.browser-v3",
  "build": {
    "frontendDist": "../electron/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../electron && npm run dev",
    "beforeBuildCommand": "cd ../electron && npm run build"
  },
  "app": {
    "title": "CCC-Browser V3",
    "windows": [
      {
        "title": "CCC-Browser V3 - RPA自动化浏览器",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8900 ws://127.0.0.1:8900"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../backend/**"
    ]
  }
}
