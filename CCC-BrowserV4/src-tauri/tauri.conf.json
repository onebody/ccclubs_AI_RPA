{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri/schema.json",
  "productName": "CCC-Browser V4",
  "version": "1.0.0",
  "identifier": "com.ccc.browser-v4",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CCC-Browser V4 - RPA自动化浏览器",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https://login.ai.ccclubs.com"
    }
  }
}
